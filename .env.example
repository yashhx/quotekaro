# QuoteKaro WhatsApp (Meta Cloud API) - set these in Netlify > Site settings > Environment variables.
# The app works WITHOUT these; they only enable real two-way WhatsApp.

# A secret string YOU invent. You type the same value into Meta's webhook "Verify token" field.
WHATSAPP_VERIFY_TOKEN=change-me-to-any-secret

# From Meta > WhatsApp > API Setup:
# NOTE: the "Temporary access token" there EXPIRES IN 24 HOURS. For anything
# beyond a quick test, generate a permanent System User token (see WHATSAPP_SETUP.md).
WHATSAPP_TOKEN=EAAG...your-permanent-access-token
WHATSAPP_PHONE_ID=1234567890

# OPTIONAL but recommended: your Meta App Secret (App settings > Basic > App secret).
# When set, the webhook rejects any POST not signed by Meta (X-Hub-Signature-256),
# so nobody can inject fake enquiries. When unset, the webhook accepts unsigned calls.
META_APP_SECRET=

# OPTIONAL: enables the "Smart reading (AI)" enquiry reader (Setup toggle in the app).
# Create a key at console.anthropic.com (needs billing). Without it the function
# returns 501 and the app silently uses its built-in regex reader.
ANTHROPIC_API_KEY=
# Optional model override; defaults to claude-haiku-4-5 (~Rs 0.10-0.25 per enquiry).
ANTHROPIC_MODEL=
# Vision model for the photo/PDF reader; defaults to claude-opus-4-8 (best at
# messy handwriting, ~Rs 2-4 per photo). Set claude-haiku-4-5 for cheaper/faster.
ANTHROPIC_VISION_MODEL=

# ===== Cloud accounts (Supabase) - optional =====
# When set, the app gets real Google login + per-customer cloud storage and the
# functions enforce per-tenant WhatsApp routing. When absent, everything runs
# in the original on-device prototype mode. Full steps: SUPABASE_SETUP.md
# Frontend (must also be set in Netlify with the VITE_ prefix - used at BUILD time):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Functions (server side):
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key - SECRET, bypasses row security; only ever lives in Netlify env:
SUPABASE_SERVICE_KEY=
